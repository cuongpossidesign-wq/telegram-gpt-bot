# Telegram GPT Bot - Environment Variables
# Copy this file to .env for local testing (DO NOT commit .env to git)

# ============================
# REQUIRED
# ============================

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (from platform.openai.com)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================
# OPTIONAL
# ============================

# Webhook URL - set this after first deployment
# e.g. https://telegram-gpt-bot-abc123-ew.a.run.app
WEBHOOK_URL=

# OpenAI model to use (default: gpt-4o-mini — cheapest and fast)
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Custom system prompt for the bot's personality
SYSTEM_PROMPT=Bạn là một trợ lý AI thông minh, thân thiện và hữu ích. Hãy trả lời bằng ngôn ngữ mà người dùng sử dụng.

# Server port (Cloud Run sets this automatically)
PORT=8080
