# Telegram Gemini Bot - Environment Variables
# Copy this file to .env for local testing (DO NOT commit .env to git)

# ============================
# REQUIRED
# ============================

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google AI SDK API Key (from https://aistudio.google.com/app/apikey)
# Sử dụng chung với gói Google AI Pro để có quota cao
GOOGLE_API_KEY=your_google_api_key_here

# ============================
# OPTIONAL
# ============================

# Model Gemini (mặc định: gemini-1.5-flash — nhanh và mạnh)
# Options: gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-1.5-flash

# Webhook URL - set this after first deployment on Vercel
# Ví dụ: https://telegram-gpt-bot-snowy.vercel.app
WEBHOOK_URL=

# Custom system prompt for the bot's personality
SYSTEM_PROMPT=Bạn là một trợ lý AI thông minh, thân thiện và hữu ích. Hãy trả lời bằng ngôn ngữ mà người dùng sử dụng.

# Server port (Vercel/Cloud Run sets this automatically)
PORT=8080
